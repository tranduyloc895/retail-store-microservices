// =============================================================================
// Jenkinsfile — Cart service (Java Spring Boot)
// =============================================================================

pipeline {
    agent {
        label 'docker-agent'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '15'))
        disableConcurrentBuilds()
        ansiColor('xterm')
    }

    environment {
        AWS_REGION    = 'ap-southeast-1'
        ECR_REPO_NAME = 'retail-store/cart'
        EKS_CLUSTER   = 'ecommerce-cluster'
        SERVICE_NAME  = 'cart'
        SERVICE_DIR   = 'src/cart'
    }

    stages {
        stage('Set IMAGE_TAG') {
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
            }
        }

        stage('Prepare Maven cache') {
            steps {
                dir('src/cart') {
                    sh './mvnw -B dependency:resolve'
                }
            }
        }

        stage('Trivy fs scan') {
            steps {
                dir('src/cart') {
                    sh '''
                        mkdir -p reports
                        trivy fs \
                            --severity HIGH,CRITICAL \
                            --exit-code 0 \
                            --no-progress \
                            --format table \
                            --output reports/trivy-fs-${IMAGE_TAG}.txt \
                            .
                        echo "===== Trivy filesystem scan ====="
                        cat reports/trivy-fs-${IMAGE_TAG}.txt
                    '''
                    archiveArtifacts artifacts: 'reports/trivy-fs-*.txt', fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            when {
                anyOf {
                    changeset 'src/cart/**'
                    triggeredBy 'UserIdCause'
                }
            }
            options {
                timeout(time: 15, unit: 'MINUTES')
            }
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    script {
                        env.ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        env.FULL_IMAGE   = "${env.ECR_REGISTRY}/${ECR_REPO_NAME}:${env.IMAGE_TAG}"
                    }
                    dir('src/cart') {
                        sh 'echo "Building: $FULL_IMAGE" && docker build -t $FULL_IMAGE .'
                    }
                }
            }
        }

        stage('Trivy image scan') {
            steps {
                sh '''
                    mkdir -p reports
                    trivy image \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --no-progress \
                        --format table \
                        --output reports/trivy-image-${IMAGE_TAG}.txt \
                        $FULL_IMAGE
                    echo "===== Trivy image scan ====="
                    cat reports/trivy-image-${IMAGE_TAG}.txt
                '''
                archiveArtifacts artifacts: 'reports/trivy-image-*.txt', fingerprint: true
            }
        }

        stage('Push to ECR') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    anyOf {
                        changeset 'src/cart/**'
                        triggeredBy 'UserIdCause'
                    }
                }
            }
            options {
                timeout(time: 10, unit: 'MINUTES')
                retry(3)
            }
            steps {
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    sh '''
                        ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_REGISTRY
                        docker push $FULL_IMAGE
                    '''
                }
            }
        }

        stage('Update GitOps') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    anyOf {
                        changeset 'src/cart/**'
                        triggeredBy 'UserIdCause'
                    }
                }
            }
            options {
                timeout(time: 5, unit: 'MINUTES')
                retry(2)
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-gitops-token',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        rm -rf gitops-repo

                        git -c credential.helper='!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f' \
                            clone https://github.com/tranduyloc895/retail-store-gitops.git gitops-repo

                        cd gitops-repo

                        git config credential.helper '!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f'

                        sed -i "s|^  tag:.*|  tag: \\"$IMAGE_TAG\\"|" apps/cart/values.yaml
                        grep -q "tag: \\"$IMAGE_TAG\\"" apps/cart/values.yaml || { echo "sed FAILED: image tag not updated"; exit 1; }

                        git config user.email "jenkins@ci.local"
                        git config user.name  "Jenkins CI"
                        git add apps/cart/values.yaml
                        git diff --staged --quiet || git commit -m "chore(cart): update image to $IMAGE_TAG"
                        git push origin main
                    '''
                }
            }
        }
    }

    post {
        success {
            script {
                def imageInfo = env.FULL_IMAGE ?: 'N/A (no changes)'
                def msg = "*${env.JOB_NAME}* #${env.BUILD_NUMBER} SUCCESS\n" +
                          "Service: `cart`\n" +
                          "Image: `${imageInfo}`\n" +
                          "<${env.BUILD_URL}|View build>"
                try {
                    slackSend(color: 'good', message: msg)
                } catch (Throwable err) {
                    echo "Slack notification skipped: ${err.message}"
                }
            }
            sh '''
                echo "Pipeline SUCCESS - Image: ${FULL_IMAGE:-(no build)}"
                kubectl get svc cart -n retail-store -o jsonpath="{.status.loadBalancer.ingress[0].hostname}" 2>/dev/null \
                    || echo "(cart thường là ClusterIP, không có LoadBalancer)"
            '''
        }
        failure {
            script {
                def msg = "*${env.JOB_NAME}* #${env.BUILD_NUMBER} FAILED\n" +
                          "Service: `cart`\n" +
                          "Stage: `${env.STAGE_NAME}`\n" +
                          "<${env.BUILD_URL}|View build log>"
                try {
                    slackSend(color: 'danger', message: msg)
                } catch (Throwable err) {
                    echo "Slack notification skipped: ${err.message}"
                }
                echo "Pipeline FAILED at stage: ${env.STAGE_NAME}"
            }
        }
        unstable {
            script {
                def msg = "*${env.JOB_NAME}* #${env.BUILD_NUMBER} UNSTABLE\n" +
                          "Service: `cart`\n" +
                          "<${env.BUILD_URL}|View build>"
                try {
                    slackSend(color: 'warning', message: msg)
                } catch (Throwable err) {
                    echo "Slack notification skipped"
                }
            }
        }
        always {
            sh 'docker rmi $FULL_IMAGE 2>/dev/null || true'
        }
    }
}
