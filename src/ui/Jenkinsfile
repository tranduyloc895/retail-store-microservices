pipeline {
    agent {
        label 'docker-agent'
    }

    environment {
        AWS_REGION    = 'ap-southeast-1'
        ECR_REPO_NAME = 'retail-store/ui'
    }

    stages {
        stage('Build Docker Image') {
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    script {
                        env.ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        env.FULL_IMAGE = "${env.ECR_REGISTRY}/${ECR_REPO_NAME}:${env.IMAGE_TAG}"
                    }
                    echo "Building UI Service image: ${env.FULL_IMAGE}"
                    dir('src/ui') {
                        sh 'docker build -t $FULL_IMAGE .'
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    sh '''
                        ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_REGISTRY
                        docker push $FULL_IMAGE
                    '''
                }
            }
        }

        stage('Deploy (GitOps)') {
            when {
                expression { return env.GITOPS_ENABLED == 'true' }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'gitops-credentials',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        rm -rf gitops-config
                        git clone https://${GIT_USER}:${GIT_TOKEN}@github.com/${GITOPS_REPO}.git gitops-config
                        cd gitops-config

                        sed -i "s|tag:.*|tag: ${IMAGE_TAG}|" ${UI_VALUES_FILE}

                        git config user.email "jenkins@ci.local"
                        git config user.name "Jenkins CI"
                        git add .
                        git commit -m "chore(ui): update image tag to ${IMAGE_TAG}" || echo "No changes"
                        git push origin ${GITOPS_BRANCH}
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS - Image: ${env.FULL_IMAGE}"
        }
        failure {
            echo "Pipeline FAILED at stage: ${env.STAGE_NAME}"
        }
        always {
            sh 'docker rmi $FULL_IMAGE || true'
        }
    }
}
