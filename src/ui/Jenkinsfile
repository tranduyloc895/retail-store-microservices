pipeline {
    agent {
        label 'docker-agent'
    }

    environment {
        AWS_REGION    = 'ap-southeast-1'
        ECR_REPO_NAME = 'retail-store/ui'
        EKS_CLUSTER   = 'ecommerce-cluster'
    }

    stages {
        stage('Build Docker Image') {
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    script {
                        env.ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        env.FULL_IMAGE = "${env.ECR_REGISTRY}/${ECR_REPO_NAME}:${env.IMAGE_TAG}"
                    }
                    dir('src/ui') {
                        sh 'echo "Building: $FULL_IMAGE" && docker build -t $FULL_IMAGE .'
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    sh '''
                        ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_REGISTRY
                        docker push $FULL_IMAGE
                    '''
                }
            }
        }

        stage('Deploy to EKS') {
            steps {
                sh '''
                    aws eks update-kubeconfig --name $EKS_CLUSTER --region $AWS_REGION

                    kubectl apply -f deploy/k8s/ui/namespace.yaml
                    kubectl apply -f deploy/k8s/ui/service.yaml

                    sed "s|IMAGE_PLACEHOLDER|$FULL_IMAGE|g" deploy/k8s/ui/deployment.yaml \
                        | kubectl apply -f -

                    kubectl rollout status deployment/ui -n retail-store --timeout=120s
                '''
            }
        }
    }

    post {
        success {
            sh '''
                echo "Pipeline SUCCESS - Image: $FULL_IMAGE"
                echo "Service URL:"
                kubectl get svc ui -n retail-store -o jsonpath="{.status.loadBalancer.ingress[0].hostname}" 2>/dev/null || echo "(LoadBalancer provisioning...)"
            '''
        }
        failure {
            echo "Pipeline FAILED at stage: ${env.STAGE_NAME}"
        }
        always {
            sh 'docker rmi $FULL_IMAGE || true'
        }
    }
}
