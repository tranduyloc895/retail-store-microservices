// =============================================================================
// Jenkinsfile — UI service

// ---------- Telegram notification helper ----------
// Gửi message qua Telegram Bot API (outbound HTTPS, hợp với Jenkins private-subnet).
// Token + chat_id lưu trong Jenkins credentials (Secret text). Best-effort:
// lỗi gửi KHÔNG làm fail build.
def notifyTelegram(String text) {
    try {
        withCredentials([
            string(credentialsId: 'telegram-bot-token', variable: 'TG_TOKEN'),
            string(credentialsId: 'telegram-chat-id',   variable: 'TG_CHAT')
        ]) {
            withEnv(["TG_TEXT=${text}"]) {
                sh '''
                    curl -s --max-time 15 -X POST \
                        "https://api.telegram.org/bot${TG_TOKEN}/sendMessage" \
                        -d chat_id="${TG_CHAT}" \
                        -d parse_mode=HTML \
                        -d disable_web_page_preview=true \
                        --data-urlencode text="${TG_TEXT}" > /dev/null
                '''
            }
        }
    } catch (Throwable err) {
        echo "Telegram notification skipped: ${err.message}"
    }
}

// Đếm số finding theo severity trong file JSON của Trivy (không phụ thuộc jq;
// dùng grep nên thiếu file/không khớp đều trả về 0, không làm fail build).
def countSeverity(String jsonFile, String severity) {
    return sh(
        script: "grep -oE '\"Severity\"[[:space:]]*:[[:space:]]*\"${severity}\"' '${jsonFile}' 2>/dev/null | wc -l | tr -d ' '",
        returnStdout: true
    ).trim()
}

// Gửi file (report) qua Telegram bằng sendDocument. Bỏ qua nếu file không tồn tại;
// lỗi gửi KHÔNG làm fail build.
def sendTelegramDoc(String filePath, String caption) {
    try {
        withCredentials([
            string(credentialsId: 'telegram-bot-token', variable: 'TG_TOKEN'),
            string(credentialsId: 'telegram-chat-id',   variable: 'TG_CHAT')
        ]) {
            withEnv(["TG_FILE=${filePath}", "TG_CAPTION=${caption}"]) {
                sh '''
                    if [ -f "${TG_FILE}" ]; then
                        curl -s --max-time 60 -X POST \
                            "https://api.telegram.org/bot${TG_TOKEN}/sendDocument" \
                            -F chat_id="${TG_CHAT}" \
                            -F caption="${TG_CAPTION}" \
                            -F document=@"${TG_FILE}" > /dev/null
                    else
                        echo "Telegram doc skipped: file not found ${TG_FILE}"
                    fi
                '''
            }
        }
    } catch (Throwable err) {
        echo "Telegram document skipped: ${err.message}"
    }
}

// ---------- Monorepo change detection ----------
// Trả về true nếu thư mục service thay đổi trong build này (so với lần build THÀNH
// CÔNG gần nhất), hoặc khi build được kích hoạt thủ công (bấm Build Now). Dùng để
// bỏ qua sạch các service không đổi trong monorepo — không tốn Trivy/Sonar và tránh
// fail do FULL_IMAGE chưa set.
def isServiceChanged(String serviceDir) {
    // Build tay -> luôn chạy
    if (!currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause').isEmpty()) {
        return true
    }
    def out = sh(returnStdout: true, script: """
        set +e
        BASE='${env.GIT_PREVIOUS_SUCCESSFUL_COMMIT ?: ''}'
        [ -z "\$BASE" ] && BASE='HEAD~1'
        # base khong ton tai (build dau / shallow clone) -> coi nhu co thay doi
        if ! git rev-parse --verify "\$BASE^{commit}" >/dev/null 2>&1; then
            echo CHANGED; exit 0
        fi
        if [ -n "\$(git diff --name-only "\$BASE" HEAD -- '${serviceDir}/')" ]; then
            echo CHANGED
        else
            echo UNCHANGED
        fi
    """).trim()
    return out == 'CHANGED'
}

pipeline {
    agent {
        label 'docker-agent'
    }

    // ---------- Options: timeout, retry, log retention ----------
    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '15'))
        disableConcurrentBuilds()
        ansiColor('xterm')
    }

    environment {
        AWS_REGION    = 'ap-southeast-1'
        ECR_REPO_NAME = 'retail-store/ui'
        EKS_CLUSTER   = 'ecommerce-cluster'
        SERVICE_NAME  = 'ui'
        SERVICE_DIR   = 'src/ui'
    }

    stages {
        // Stage đầu: phát hiện thay đổi. Nếu service không đổi (và không build tay)
        // -> set cờ false + NOT_BUILT, mọi stage sau bị bỏ qua -> kết thúc tức thì.
        stage('Detect changes') {
            steps {
                script {
                    env.SERVICE_CHANGED = isServiceChanged(env.SERVICE_DIR) ? 'true' : 'false'
                    if (env.SERVICE_CHANGED == 'true') {
                        echo "Changes detected in ${env.SERVICE_DIR} (or manual build) -> running full pipeline."
                    } else {
                        echo "No changes in ${env.SERVICE_DIR} -> skipping (NOT_BUILT)."
                        currentBuild.result = 'NOT_BUILT'
                    }
                }
            }
        }

        stage('Set IMAGE_TAG') {
            when { expression { env.SERVICE_CHANGED == 'true' } }
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
            }
        }

        stage('Prepare Maven cache') {
            when { expression { env.SERVICE_CHANGED == 'true' } }
            steps {
                dir('src/ui') {
                    sh 'chmod +x ./mvnw && ./mvnw -B dependency:resolve'
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir('src/ui') {
                    sh './mvnw test -B'
                }
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                    // Coverage report đã được tạo bởi JaCoCo trong stage SonarCloud
                }
            }
        }

        stage('Trivy fs scan') {
            when { expression { env.SERVICE_CHANGED == 'true' } }
            steps {
                dir('src/ui') {
                    sh '''
                        mkdir -p reports

                        # Locate the Trivy HTML template (installed via apt) or download a fallback copy
                        TPL=/usr/local/share/trivy/templates/html.tpl
                        if [ ! -f "$TPL" ]; then
                            curl -sSL -o reports/html.tpl https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl
                            TPL=reports/html.tpl
                        fi

                        # Same scan exported as console table (.txt), HTML report (.html) and JSON (for counts)
                        trivy fs --severity HIGH,CRITICAL --exit-code 0 --no-progress --format table --output reports/trivy-fs-${IMAGE_TAG}.txt .
                        trivy fs --severity HIGH,CRITICAL --exit-code 0 --no-progress --format template --template @$TPL --output reports/trivy-fs-${IMAGE_TAG}.html .
                        trivy fs --severity HIGH,CRITICAL --exit-code 0 --no-progress --format json --output reports/trivy-fs-${IMAGE_TAG}.json .

                        echo "===== Trivy filesystem scan ====="
                        cat reports/trivy-fs-${IMAGE_TAG}.txt
                    '''
                    archiveArtifacts artifacts: 'reports/trivy-fs-*.txt,reports/trivy-fs-*.html', fingerprint: true
                }
                script {
                    env.FS_HIGH = countSeverity("src/ui/reports/trivy-fs-${env.IMAGE_TAG}.json", "HIGH")
                    env.FS_CRIT = countSeverity("src/ui/reports/trivy-fs-${env.IMAGE_TAG}.json", "CRITICAL")
                }
            }
        }

        stage('SonarCloud Analysis') {
            when { expression { env.SERVICE_CHANGED == 'true' } }
            steps {
                withCredentials([string(credentialsId: 'sonarcloud-token', variable: 'SONAR_TOKEN')]) {
                    dir('src/ui') {
                        sh '''
                            mkdir -p reports/sonar
                            ./mvnw clean verify sonar:sonar \
                                -Dsonar.token=${SONAR_TOKEN} \
                                -Dsonar.branch.name=main

                            # archive scanner metadata if available
                            if [ -f target/sonar/report-task.txt ]; then
                                cp target/sonar/report-task.txt reports/sonar/sonar-report-task.txt
                            fi
                            if [ -f target/sonar/report-task.json ]; then
                                cp target/sonar/report-task.json reports/sonar/sonar-report-task.json
                            fi
                        '''
                        archiveArtifacts artifacts: 'reports/sonar/*', fingerprint: true
                    }
                }
                // Lấy dashboardUrl từ report-task.txt để gửi link qua Telegram.
                // 2>/dev/null + '|| true' đảm bảo không làm fail build nếu thiếu file.
                script {
                    env.SONAR_URL = sh(
                        script: "grep '^dashboardUrl=' src/ui/reports/sonar/sonar-report-task.txt 2>/dev/null | cut -d= -f2- || true",
                        returnStdout: true
                    ).trim()
                }
            }
        }

        stage('Build Docker Image') {
            when {
                expression { env.SERVICE_CHANGED == 'true' }
            }
            options {
                timeout(time: 15, unit: 'MINUTES')
            }
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    script {
                        env.ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        env.FULL_IMAGE   = "${env.ECR_REGISTRY}/${ECR_REPO_NAME}:${env.IMAGE_TAG}"
                    }
                    dir('src/ui') {
                        sh 'echo "Building: $FULL_IMAGE" && docker build -t $FULL_IMAGE .'
                    }
                }
            }
        }

        stage('Trivy image scan') {
            when { expression { env.SERVICE_CHANGED == 'true' } }
            steps {
                sh '''
                    mkdir -p reports

                    # Locate the Trivy HTML template (installed via apt) or download a fallback copy
                    TPL=/usr/local/share/trivy/templates/html.tpl
                    if [ ! -f "$TPL" ]; then
                        curl -sSL -o reports/html.tpl https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/html.tpl
                        TPL=reports/html.tpl
                    fi

                    # Same scan exported as console table (.txt), HTML report (.html) and JSON (for counts)
                    trivy image --severity HIGH,CRITICAL --exit-code 0 --no-progress --format table --output reports/trivy-image-${IMAGE_TAG}.txt $FULL_IMAGE
                    trivy image --severity HIGH,CRITICAL --exit-code 0 --no-progress --format template --template @$TPL --output reports/trivy-image-${IMAGE_TAG}.html $FULL_IMAGE
                    trivy image --severity HIGH,CRITICAL --exit-code 0 --no-progress --format json --output reports/trivy-image-${IMAGE_TAG}.json $FULL_IMAGE

                    echo "===== Trivy image scan ====="
                    cat reports/trivy-image-${IMAGE_TAG}.txt
                '''
                archiveArtifacts artifacts: 'reports/trivy-image-*.txt,reports/trivy-image-*.html', fingerprint: true
                script {
                    env.IMG_HIGH = countSeverity("reports/trivy-image-${env.IMAGE_TAG}.json", "HIGH")
                    env.IMG_CRIT = countSeverity("reports/trivy-image-${env.IMAGE_TAG}.json", "CRITICAL")
                }
            }
        }

        stage('Push to ECR') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    expression { env.SERVICE_CHANGED == 'true' }
                }
            }
            options {
                timeout(time: 10, unit: 'MINUTES')
                retry(3)
            }
            steps {
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    sh '''
                        ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_REGISTRY
                        docker push $FULL_IMAGE
                    '''
                }
            }
        }

        stage('Update GitOps') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    expression { env.SERVICE_CHANGED == 'true' }
                }
            }
            options {
                timeout(time: 5, unit: 'MINUTES')
                retry(2)
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-gitops-token',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        rm -rf gitops-repo

                        git -c credential.helper='!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f' \
                            clone https://github.com/tranduyloc895/retail-store-gitops.git gitops-repo

                        cd gitops-repo

                        git config credential.helper '!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f'

                        sed -i "s|^  tag:.*|  tag: \\"$IMAGE_TAG\\"|" apps/ui/values.yaml
                        grep -q "tag: \\"$IMAGE_TAG\\"" apps/ui/values.yaml || { echo "sed FAILED: image tag not updated"; exit 1; }

                        git config user.email "jenkins@ci.local"
                        git config user.name "Jenkins CI"
                        git add apps/ui/values.yaml
                        git diff --staged --quiet || git commit -m "chore(ui): update image to $IMAGE_TAG"
                        git push origin main
                    '''
                }
            }
        }
    }

    // ---------- POST: Telegram notification + cleanup ----------
    post {
        success {
            script {
                def imageInfo = env.FULL_IMAGE ?: 'N/A (no changes)'
                def sonarLine = env.SONAR_URL ? "SonarCloud: <a href=\"${env.SONAR_URL}\">View dashboard</a>\n" : ""
                def msg = "<b>✅ ${env.JOB_NAME} #${env.BUILD_NUMBER} — SUCCESS</b>\n" +
                          "Service: <code>ui</code>\n" +
                          "Image: <code>${imageInfo}</code>\n" +
                          "Trivy fs: HIGH=${env.FS_HIGH ?: '-'} CRIT=${env.FS_CRIT ?: '-'}\n" +
                          "Trivy image: HIGH=${env.IMG_HIGH ?: '-'} CRIT=${env.IMG_CRIT ?: '-'}\n" +
                          sonarLine +
                          "<a href=\"${env.BUILD_URL}\">View build</a>"
                notifyTelegram(msg)
                sendTelegramDoc("src/ui/reports/trivy-fs-${env.IMAGE_TAG}.html",  "Trivy fs report — ui #${env.BUILD_NUMBER}")
                sendTelegramDoc("reports/trivy-image-${env.IMAGE_TAG}.html",       "Trivy image report — ui #${env.BUILD_NUMBER}")
                sendTelegramDoc("src/ui/reports/sonar/sonar-report-task.txt",      "SonarCloud report-task — ui #${env.BUILD_NUMBER}")
            }
        }
        failure {
            script {
                def msg = "<b>❌ ${env.JOB_NAME} #${env.BUILD_NUMBER} — FAILED</b>\n" +
                          "Service: <code>ui</code>\n" +
                          "Stage: <code>${env.STAGE_NAME}</code>\n" +
                          "<a href=\"${env.BUILD_URL}\">View build log</a>"
                notifyTelegram(msg)
                echo "Pipeline FAILED at stage: ${env.STAGE_NAME}"
            }
        }
        unstable {
            script {
                def msg = "<b>⚠️ ${env.JOB_NAME} #${env.BUILD_NUMBER} — UNSTABLE</b>\n" +
                          "Service: <code>ui</code>\n" +
                          "Có test/scan issue, build vẫn pass.\n" +
                          "<a href=\"${env.BUILD_URL}\">View build</a>"
                notifyTelegram(msg)
            }
        }
        always {
            sh 'docker rmi $FULL_IMAGE 2>/dev/null || true'
        }
    }
}
