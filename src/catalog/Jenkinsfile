// =============================================================================
// Jenkinsfile — Catalog service (Go)
// =============================================================================
// Fix theo phản hồi GVHD:
//   [1] Token GitHub không nằm trong git URL (dùng credential helper)
//   [2] Timeout + retry (options block)
//   [3] when { branch 'main' } — chỉ Push/UpdateGitOps khi merge vào main
//   [4] when { changeset } — skip stage nếu không có thay đổi trong src/catalog/
//   [5] Slack notification trong post block
// =============================================================================

pipeline {
    agent {
        label 'docker-agent'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '15'))
        disableConcurrentBuilds()
        ansiColor('xterm')
    }

    environment {
        AWS_REGION    = 'ap-southeast-1'
        ECR_REPO_NAME = 'retail-store/catalog'
        EKS_CLUSTER   = 'ecommerce-cluster'
        SERVICE_NAME  = 'catalog'
        SERVICE_DIR   = 'src/catalog'
    }

    stages {
        stage('Build Docker Image') {
            when {
                anyOf {
                    changeset 'src/catalog/**'
                    triggeredBy 'UserIdCause'
                }
            }
            options {
                timeout(time: 15, unit: 'MINUTES')
            }
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    script {
                        env.ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        env.FULL_IMAGE   = "${env.ECR_REGISTRY}/${ECR_REPO_NAME}:${env.IMAGE_TAG}"
                    }
                    dir('src/catalog') {
                        sh 'echo "Building: $FULL_IMAGE" && docker build -t $FULL_IMAGE .'
                    }
                }
            }
        }

        stage('Push to ECR') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    anyOf {
                        changeset 'src/catalog/**'
                        triggeredBy 'UserIdCause'
                    }
                }
            }
            options {
                timeout(time: 10, unit: 'MINUTES')
                retry(3)
            }
            steps {
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    sh '''
                        ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_REGISTRY
                        docker push $FULL_IMAGE
                    '''
                }
            }
        }

        stage('Update GitOps') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    anyOf {
                        changeset 'src/catalog/**'
                        triggeredBy 'UserIdCause'
                    }
                }
            }
            options {
                timeout(time: 5, unit: 'MINUTES')
                retry(2)
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-gitops-token',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        rm -rf gitops-repo

                        git -c credential.helper='!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f' \
                            clone https://github.com/tranduyloc895/retail-store-gitops.git gitops-repo

                        cd gitops-repo

                        git config credential.helper '!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f'

                        sed -i "s|image:.*retail-store/catalog.*|image: $FULL_IMAGE|" apps/catalog/deployment.yml
                        grep -q "$FULL_IMAGE" apps/catalog/deployment.yml || { echo "sed FAILED: image tag not updated"; exit 1; }

                        git config user.email "jenkins@ci.local"
                        git config user.name  "Jenkins CI"
                        git add apps/catalog/deployment.yml
                        git diff --staged --quiet || git commit -m "chore(catalog): update image to $IMAGE_TAG"
                        git push origin main
                    '''
                }
            }
        }
    }

    post {
        success {
            script {
                def imageInfo = env.FULL_IMAGE ?: 'N/A (no changes)'
                def msg = "✅ *${env.JOB_NAME}* #${env.BUILD_NUMBER} SUCCESS\n" +
                          "Service: `catalog`\n" +
                          "Image: `${imageInfo}`\n" +
                          "<${env.BUILD_URL}|View build>"
                try {
                    slackSend(color: 'good', message: msg)
                } catch (err) {
                    echo "Slack notification skipped: ${err.message}"
                }
            }
            sh '''
                echo "Pipeline SUCCESS - Image: ${FULL_IMAGE:-(no build)}"
                kubectl get svc catalog -n retail-store -o jsonpath="{.status.loadBalancer.ingress[0].hostname}" 2>/dev/null \
                    || echo "(catalog thường là ClusterIP, không có LoadBalancer)"
            '''
        }
        failure {
            script {
                def msg = "❌ *${env.JOB_NAME}* #${env.BUILD_NUMBER} FAILED\n" +
                          "Service: `catalog`\n" +
                          "Stage: `${env.STAGE_NAME}`\n" +
                          "<${env.BUILD_URL}|View build log>"
                try {
                    slackSend(color: 'danger', message: msg)
                } catch (err) {
                    echo "Slack notification skipped: ${err.message}"
                }
                echo "Pipeline FAILED at stage: ${env.STAGE_NAME}"
            }
        }
        unstable {
            script {
                def msg = "⚠️ *${env.JOB_NAME}* #${env.BUILD_NUMBER} UNSTABLE\n" +
                          "Service: `catalog`\n" +
                          "<${env.BUILD_URL}|View build>"
                try {
                    slackSend(color: 'warning', message: msg)
                } catch (err) {
                    echo "Slack notification skipped"
                }
            }
        }
        always {
            sh 'docker rmi $FULL_IMAGE 2>/dev/null || true'
        }
    }
}
