// =============================================================================
// Jenkinsfile — Orders service (Java Spring Boot)
// =============================================================================

pipeline {
    agent {
        label 'docker-agent'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '15'))
        disableConcurrentBuilds()
        ansiColor('xterm')
    }

    environment {
        AWS_REGION    = 'ap-southeast-1'
        ECR_REPO_NAME = 'retail-store/orders'
        EKS_CLUSTER   = 'ecommerce-cluster'
        SERVICE_NAME  = 'orders'
        SERVICE_DIR   = 'src/orders'
    }

    stages {
        stage('Set IMAGE_TAG') {
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
            }
        }

        stage('Prepare Maven cache') {
            steps {
                dir('src/orders') {
                    sh 'chmod +x ./mvnw && ./mvnw -B dependency:resolve'
                }
            }
        }

        stage('Trivy fs scan') {
            steps {
                dir('src/orders') {
                    sh '''
                        mkdir -p reports
                        trivy fs \
                            --severity HIGH,CRITICAL \
                            --exit-code 0 \
                            --no-progress \
                            --format json \
                            --output reports/trivy-fs-${IMAGE_TAG}.json \
                            .
                        python - <<'PY'
import json, html, os, pathlib
service = os.environ.get('SERVICE_NAME', 'service')
tag = os.environ['IMAGE_TAG']
report_json = pathlib.Path('reports') / f'trivy-fs-{tag}.json'
report_html = pathlib.Path('reports') / f'trivy-fs-{tag}.html'
data = json.loads(report_json.read_text(encoding='utf-8'))
severity_styles = {
    'CRITICAL': '#d32f2f',
    'HIGH': '#f57c00',
    'MEDIUM': '#1976d2',
    'LOW': '#388e3c',
    'UNKNOWN': '#616161'
}
rows = []
counts = {}
for result in data.get('Results', []):
    target = result.get('Target', '')
    for vuln in result.get('Vulnerabilities', []) or []:
        sev = vuln.get('Severity', 'UNKNOWN')
        counts[sev] = counts.get(sev, 0) + 1
        refs = vuln.get('References', []) or []
        ref_html = '<br>'.join(f'<a href="{html.escape(r)}">{html.escape(r)}</a>' for r in refs)
        rows.append(f"""<tr>
<td>{html.escape(target)}</td>
<td>{html.escape(vuln.get('VulnerabilityID', ''))}</td>
<td>{html.escape(vuln.get('PkgName', ''))}</td>
<td>{html.escape(vuln.get('InstalledVersion', ''))}</td>
<td>{html.escape(vuln.get('FixedVersion', ''))}</td>
<td style=\"background:{severity_styles.get(sev, '#888')};color:#fff;text-align:center\">{html.escape(sev)}</td>
<td>{html.escape(vuln.get('Title', ''))}</td>
<td>{html.escape(vuln.get('Description', ''))}</td>
<td>{ref_html}</td>
</tr>""")
summary_cells = ''.join(f'<td style="padding: 0.5rem; background:{severity_styles.get(sev, "#888")}; color:#fff; text-align:center;">{html.escape(sev)}: {count}</td>' for sev, count in sorted(counts.items(), key=lambda x: ['CRITICAL','HIGH','MEDIUM','LOW','UNKNOWN'].index(x[0]) if x[0] in ['CRITICAL','HIGH','MEDIUM','LOW','UNKNOWN'] else 5))
if not rows:
    rows_html = '<tr><td colspan="9" style="text-align:center;padding:1rem;">No vulnerabilities found.</td></tr>'
else:
    rows_html = '\n'.join(rows)
summary_html = f'<tr>{summary_cells}</tr>' if counts else '<tr><td colspan="9" style="text-align:center;padding:1rem;">No vulnerabilities found.</td></tr>'
html_content = f'''<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Trivy FS Report - {html.escape(service)} - {html.escape(tag)}</title>
<style>
body {{ font-family: Arial, sans-serif; margin: 0; padding: 1.5rem; background: #f4f6f8; color: #212121; }}
header {{ margin-bottom: 1.5rem; }}
h1 {{ margin: 0; font-size: 1.8rem; }}
section.summary {{ margin-bottom: 1rem; }}
table {{ width: 100%; border-collapse: collapse; background: #fff; box-shadow: 0 0 12px rgba(0,0,0,0.05); }}
th, td {{ padding: 0.75rem 0.9rem; border-bottom: 1px solid #e0e0e0; text-align: left; }}
th {{ background: #1976d2; color: white; position: sticky; top: 0; }}
tr:nth-child(even) {{ background: #fafafa; }}
</style>
</head>
<body>
<header>
<h1>Trivy FS Scan Report</h1>
<p><strong>Service:</strong> {html.escape(service)} &nbsp; | &nbsp; <strong>Image Tag:</strong> {html.escape(tag)}</p>
</header>
<section class="summary">
<table>
<thead><tr><th colspan="9">Severity summary</th></tr></thead>
<tbody>{summary_html}</tbody>
</table>
</section>
<section>
<table>
<thead>
<tr>
<th>Target</th><th>ID</th><th>Package</th><th>Installed</th><th>Fixed</th><th>Severity</th><th>Title</th><th>Description</th><th>References</th>
</tr>
</thead>
<tbody>
{rows_html}
</tbody>
</table>
</section>
</body>
</html>'''
report_html.write_text(html_content, encoding='utf-8')
PY
                    '''
                    archiveArtifacts artifacts: 'reports/trivy-fs-*.html', fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            when {
                anyOf {
                    changeset 'src/orders/**'
                    triggeredBy 'UserIdCause'
                }
            }
            options {
                timeout(time: 15, unit: 'MINUTES')
            }
            steps {
                script {
                    env.IMAGE_TAG = sh(script: 'git rev-parse --short=7 HEAD', returnStdout: true).trim()
                }
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    script {
                        env.ECR_REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        env.FULL_IMAGE   = "${env.ECR_REGISTRY}/${ECR_REPO_NAME}:${env.IMAGE_TAG}"
                    }
                    dir('src/orders') {
                        sh 'echo "Building: $FULL_IMAGE" && docker build -t $FULL_IMAGE .'
                    }
                }
            }
        }

        stage('Trivy image scan') {
            steps {
                sh '''
                    mkdir -p reports
                    trivy image \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --no-progress \
                        --format json \
                        --output reports/trivy-image-${IMAGE_TAG}.json \
                        $FULL_IMAGE
                    python - <<'PY'
import json, html, os, pathlib
service = os.environ.get('SERVICE_NAME', 'service')
tag = os.environ['IMAGE_TAG']
report_json = pathlib.Path('reports') / f'trivy-image-{tag}.json'
report_html = pathlib.Path('reports') / f'trivy-image-{tag}.html'
data = json.loads(report_json.read_text(encoding='utf-8'))
severity_styles = {
    'CRITICAL': '#d32f2f',
    'HIGH': '#f57c00',
    'MEDIUM': '#1976d2',
    'LOW': '#388e3c',
    'UNKNOWN': '#616161'
}
rows = []
counts = {}
for result in data.get('Results', []):
    target = result.get('Target', '')
    for vuln in result.get('Vulnerabilities', []) or []:
        sev = vuln.get('Severity', 'UNKNOWN')
        counts[sev] = counts.get(sev, 0) + 1
        refs = vuln.get('References', []) or []
        ref_html = '<br>'.join(f'<a href="{html.escape(r)}">{html.escape(r)}</a>' for r in refs)
        rows.append(f"""<tr>
<td>{html.escape(target)}</td>
<td>{html.escape(vuln.get('VulnerabilityID', ''))}</td>
<td>{html.escape(vuln.get('PkgName', ''))}</td>
<td>{html.escape(vuln.get('InstalledVersion', ''))}</td>
<td>{html.escape(vuln.get('FixedVersion', ''))}</td>
<td style=\"background:{severity_styles.get(sev, '#888')};color:#fff;text-align:center\">{html.escape(sev)}</td>
<td>{html.escape(vuln.get('Title', ''))}</td>
<td>{html.escape(vuln.get('Description', ''))}</td>
<td>{ref_html}</td>
</tr>""")
summary_cells = ''.join(f'<td style="padding: 0.5rem; background:{severity_styles.get(sev, "#888")}; color:#fff; text-align:center;">{html.escape(sev)}: {count}</td>' for sev, count in sorted(counts.items(), key=lambda x: ['CRITICAL','HIGH','MEDIUM','LOW','UNKNOWN'].index(x[0]) if x[0] in ['CRITICAL','HIGH','MEDIUM','LOW','UNKNOWN'] else 5))
if not rows:
    rows_html = '<tr><td colspan="9" style="text-align:center;padding:1rem;">No vulnerabilities found.</td></tr>'
else:
    rows_html = '\n'.join(rows)
summary_html = f'<tr>{summary_cells}</tr>' if counts else '<tr><td colspan="9" style="text-align:center;padding:1rem;">No vulnerabilities found.</td></tr>'
html_content = f'''<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Trivy Image Report - {html.escape(service)} - {html.escape(tag)}</title>
<style>
body {{ font-family: Arial, sans-serif; margin: 0; padding: 1.5rem; background: #f4f6f8; color: #212121; }}
header {{ margin-bottom: 1.5rem; }}
h1 {{ margin: 0; font-size: 1.8rem; }}
section.summary {{ margin-bottom: 1rem; }}
table {{ width: 100%; border-collapse: collapse; background: #fff; box-shadow: 0 0 12px rgba(0,0,0,0.05); }}
th, td {{ padding: 0.75rem 0.9rem; border-bottom: 1px solid #e0e0e0; text-align: left; }}
th {{ background: #1976d2; color: white; position: sticky; top: 0; }}
tr:nth-child(even) {{ background: #fafafa; }}
</style>
</head>
<body>
<header>
<h1>Trivy Image Scan Report</h1>
<p><strong>Service:</strong> {html.escape(service)} &nbsp; | &nbsp; <strong>Image Tag:</strong> {html.escape(tag)}</p>
</header>
<section class="summary">
<table>
<thead><tr><th colspan="9">Severity summary</th></tr></thead>
<tbody>{summary_html}</tbody>
</table>
</section>
<section>
<table>
<thead>
<tr>
<th>Target</th><th>ID</th><th>Package</th><th>Installed</th><th>Fixed</th><th>Severity</th><th>Title</th><th>Description</th><th>References</th>
</tr>
</thead>
<tbody>
{rows_html}
</tbody>
</table>
</section>
</body>
</html>'''
report_html.write_text(html_content, encoding='utf-8')
PY
                    '''
                archiveArtifacts artifacts: 'reports/trivy-image-*.html', fingerprint: true
            }
        }
        
        stage('Push to ECR') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    anyOf {
                        changeset 'src/orders/**'
                        triggeredBy 'UserIdCause'
                    }
                }
            }
            options {
                timeout(time: 10, unit: 'MINUTES')
                retry(3)
            }
            steps {
                withCredentials([string(credentialsId: 'aws-account-id', variable: 'AWS_ACCOUNT_ID')]) {
                    sh '''
                        ECR_REGISTRY="${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_REGISTRY
                        docker push $FULL_IMAGE
                    '''
                }
            }
        }

        stage('Update GitOps') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                    anyOf {
                        changeset 'src/orders/**'
                        triggeredBy 'UserIdCause'
                    }
                }
            }
            options {
                timeout(time: 5, unit: 'MINUTES')
                retry(2)
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-gitops-token',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        rm -rf gitops-repo

                        git -c credential.helper='!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f' \
                            clone https://github.com/tranduyloc895/retail-store-gitops.git gitops-repo

                        cd gitops-repo

                        git config credential.helper '!f() { echo "username=$GIT_USER"; echo "password=$GIT_TOKEN"; }; f'

                        sed -i "s|^  tag:.*|  tag: \\"$IMAGE_TAG\\"|" apps/orders/values.yaml
                        grep -q "tag: \\"$IMAGE_TAG\\"" apps/orders/values.yaml || { echo "sed FAILED: image tag not updated"; exit 1; }

                        git config user.email "jenkins@ci.local"
                        git config user.name  "Jenkins CI"
                        git add apps/orders/values.yaml
                        git diff --staged --quiet || git commit -m "chore(orders): update image to $IMAGE_TAG"
                        git push origin main
                    '''
                }
            }
        }
    }

    post {
        success {
            script {
                def imageInfo = env.FULL_IMAGE ?: 'N/A (no changes)'
                def msg = "*${env.JOB_NAME}* #${env.BUILD_NUMBER} SUCCESS\n" +
                          "Service: `orders`\n" +
                          "Image: `${imageInfo}`\n" +
                          "<${env.BUILD_URL}|View build>"
                try {
                    slackSend(color: 'good', message: msg)
                } catch (Throwable err) {
                    echo "Slack notification skipped: ${err.message}"
                }
            }
            sh '''
                echo "Pipeline SUCCESS - Image: ${FULL_IMAGE:-(no build)}"
                kubectl get svc orders -n retail-store -o jsonpath="{.status.loadBalancer.ingress[0].hostname}" 2>/dev/null \
                    || echo "(orders thường là ClusterIP, không có LoadBalancer)"
            '''
        }
        failure {
            script {
                def msg = "*${env.JOB_NAME}* #${env.BUILD_NUMBER} FAILED\n" +
                          "Service: `orders`\n" +
                          "Stage: `${env.STAGE_NAME}`\n" +
                          "<${env.BUILD_URL}|View build log>"
                try {
                    slackSend(color: 'danger', message: msg)
                } catch (Throwable err) {
                    echo "Slack notification skipped: ${err.message}"
                }
                echo "Pipeline FAILED at stage: ${env.STAGE_NAME}"
            }
        }
        unstable {
            script {
                def msg = "*${env.JOB_NAME}* #${env.BUILD_NUMBER} UNSTABLE\n" +
                          "Service: `orders`\n" +
                          "<${env.BUILD_URL}|View build>"
                try {
                    slackSend(color: 'warning', message: msg)
                } catch (Throwable err) {
                    echo "Slack notification skipped"
                }
            }
        }
        always {
            sh 'docker rmi $FULL_IMAGE 2>/dev/null || true'
        }
    }
}
